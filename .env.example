# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT="your-project-id"

# RAG Configuration (Vertex AI Search)
VERTEX_SEARCH_DATA_STORE_ID="your-data-store-id"
VERTEX_SEARCH_LOCATION="global"

# AI Configuration (Model Assignments)
LOCATION="us-central1"
VERTEX_AI_LOCATION="us-central1" 
GEMINI_MODEL="gemini-1.5-flash-001"
GEMINI_PRO_MODEL="gemini-1.5-pro-001"

# LLM Provider Keys
# Get Gemini key at: https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key-here"

# Get Groq keys at: https://console.groq.com/
# PolicyIQ uses 3 keys for load balancing across 50 concurrent agents
GROQ_API_KEY_1="your-first-groq-api-key-here"
GROQ_API_KEY_2="your-second-groq-api-key-here"
GROQ_API_KEY_3="your-third-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

# Infrastructure & Credentials
# Ensure this file exists in your root and is added to .gitignore
GOOGLE_APPLICATION_CREDENTIALS="service_account.json"